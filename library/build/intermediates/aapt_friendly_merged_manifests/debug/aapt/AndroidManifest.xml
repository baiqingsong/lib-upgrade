<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dawn.lib_upgrade" >

    <uses-sdk android:minSdkVersion="28" />

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 存储权限（Android 10 以下需要） -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- 安装 APK 权限 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application>

        <!-- 下载前台服务 -->
        <service
            android:name="com.dawn.lib_upgrade.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- FileProvider（用于 Android 7.0+ APK 安装） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="dollar_openBracket_applicationId_closeBracket.upgrade.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true" >
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/upgrade_file_paths" />
        </provider>
    </application>

</manifest>